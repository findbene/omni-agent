{
  "manifest_version": 3,
  "name": "Omni-Agent",
  "version": "3.0.0",
  "description": "The most powerful AI browser assistant. Surpasses HARPA AI and Sider: Deep Research, Multi-AI, Knowledge Base, Web Automation, Screenshot Analysis, and more.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle Omni-Agent",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabCapture",
    "offscreen",
    "alarms",
    "notifications",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Toggle Omni-Agent sidebar"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-DctRDFSo.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "icons/*.png",
        "assets/pdf.worker-xSiVJ7U_.mjs",
        "assets/storage-BlwLxR4a.js",
        "assets/providers-D-5k4Gey.js",
        "assets/index.tsx-CMLtpbUm.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
